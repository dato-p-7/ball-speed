#include <SoftwareSerial.h>

SoftwareSerial bluetooth(10, 11);

const int trig1 = 2;
const int echo1 = 3;
const int trig2 = 4;
const int echo2 = 5;
const int pinGreen = 7;
const int pinRed = 8;

const float DISTANCE = 1.13;
const float TRIGGER_DIST = 30.0;

float getDistance(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  long duration = pulseIn(echoPin, HIGH, 30000);
  if (duration == 0) return -1;
  return (duration * 0.0343) / 2;
}

void setRed() {
  digitalWrite(pinRed, HIGH);
  digitalWrite(pinGreen, LOW);
}

void setGreen() {
  digitalWrite(pinGreen, HIGH);
  digitalWrite(pinRed, LOW);
}

void setup() {
  pinMode(trig1, OUTPUT);
  pinMode(echo1, INPUT);
  pinMode(trig2, OUTPUT);
  pinMode(echo2, INPUT);
  pinMode(pinGreen, OUTPUT);
  pinMode(pinRed, OUTPUT);
  Serial.begin(9600);
  bluetooth.begin(9600);
  setRed();
  bluetooth.println("Ball Speed Test Ready!");
  bluetooth.println("Place ball in front of S1");
}

void loop() {
  float d1 = getDistance(trig1, echo1);

  // No ball at S1 — red light
  if (d1 <= 0 || d1 >= TRIGGER_DIST) {
    setRed();
    return;
  }

  // Ball detected at S1 — green light
  setGreen();
  bluetooth.println("S1: Ball ready - HIT IT!");
  Serial.println("Ball at S1!");

  // Wait for ball to leave S1
  while (true) {
    float check = getDistance(trig1, echo1);
    if (check <= 0 || check >= TRIGGER_DIST) break;
    delay(5);
  }

  // T1 — ball just left sensor 1
  unsigned long t1 = micros();
  setRed();
  bluetooth.println("Ball kicked! Waiting S2...");
  Serial.println("Ball kicked!");

  // Wait for ball to reach sensor 2
  bool caught = false;
  unsigned long t2 = 0;
  unsigned long startWait = millis();

  while (millis() - startWait < 5000) {
    float d2 = getDistance(trig2, echo2);
    if (d2 > 0 && d2 < TRIGGER_DIST) {
      t2 = micros();
      caught = true;
      break;
    }
    delay(5);
  }

  if (caught) {
    float dt = (t2 - t1) / 1000000.0;
    float speed_ms = DISTANCE / dt;
    float speed_kmh = speed_ms * 3.6;

    setGreen();

    bluetooth.print("Speed: ");
    bluetooth.print(speed_kmh, 1);
    bluetooth.println(" km/h");
    bluetooth.print("Time: ");
    bluetooth.print(dt, 4);
    bluetooth.println(" s");
    bluetooth.println("----------");

    Serial.print("Speed: ");
    Serial.print(speed_kmh, 1);
    Serial.println(" km/h");

    delay(5000);

  } else {
    setRed();
    bluetooth.println("Missed S2! Try again...");
    bluetooth.println("----------");
    Serial.println("Missed S2!");
    delay(2000);
  }

  setRed();
  bluetooth.println("Place ball in front of S1");
}
